{
  "name": "proof-of-work-anywhere",
  "version": "1.0.0",
  "description": "Cloud-agnostic enterprise micro-SaaS for proof of work validation",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend/*",
    "backend/workers/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:admin\" \"npm run dev:worker\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd frontend/admin && npm run dev",
    "dev:worker": "cd frontend/worker && npm run dev",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "test:e2e": "cd tests/e2e && npm run test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write .",
    "build": "npm run build:backend && npm run build:admin && npm run build:worker",
    "build:backend": "cd backend && npm run build",
    "build:admin": "cd frontend/admin && npm run build",
    "build:worker": "cd frontend/worker && npm run build",
    "docker:build": "docker-compose -f infrastructure/docker-compose/docker-compose.yml build",
    "docker:up": "docker-compose -f infrastructure/docker-compose/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker-compose/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
